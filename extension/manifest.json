{
  "manifest_version": 3,
  "name": "Локальный мост DeepSeek",
  "version": "0.1.0",
  "description": "Открывает DeepSeek в браузере, отправляет запросы и возвращает ответы в локальный Python-клиент по WebSocket.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://chat.deepseek.com/*", "ws://127.0.0.1/*"],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Локальный мост DeepSeek",
    "default_popup": "src/popup/popup.html"
  }
}

